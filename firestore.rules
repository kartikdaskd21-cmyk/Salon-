rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'client' or 'admin')
    //   - phone: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: services
    // Document ID: {serviceId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - description: string (optional)
    //   - price: number (required)
    //   - durationMinutes: number (required)
    //   - imageUrl: string (optional)
    //   - isActive: boolean (required)
    //
    // Collection: bookings
    // Document ID: {bookingId}
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - customerName: string (required)
    //   - customerPhone: string (optional)
    //   - serviceIds: list (required)
    //   - totalAmount: number (required)
    //   - date: string (required)
    //   - timeSlot: string (required)
    //   - status: string (required, 'pending', 'confirmed', 'completed', 'cancelled')
    //   - createdAt: timestamp (required)
    //
    // Collection: reviews
    // Document ID: {reviewId}
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - customerName: string (required)
    //   - serviceIds: list (required)
    //   - serviceNames: list (required)
    //   - rating: number (required)
    //   - text: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isHardcodedAdmin() {
      return isAuthenticated() &&
        request.auth.token.email != null && 
        request.auth.token.email.lower() == "kartikdas.kd21@gmail.com" && 
        request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isHardcodedAdmin() || 
             (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.role in ['client', 'admin'] &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidBooking() {
      let data = request.resource.data;
      return hasRequiredFields(['id', 'userId', 'customerName', 'serviceIds', 'totalAmount', 'date', 'timeSlot', 'status', 'createdAt']) &&
             data.id is string && data.userId is string &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.serviceIds is list && data.serviceIds.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.date is string && data.timeSlot is string &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'] &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidReview() {
      let data = request.resource.data;
      return hasRequiredFields(['id', 'userId', 'customerName', 'serviceIds', 'serviceNames', 'rating', 'createdAt']) &&
             data.id is string && data.userId is string &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.serviceIds is list && data.serviceIds.size() > 0 &&
             data.serviceNames is list && data.serviceNames.size() > 0 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // match /{document=**} {
    //   allow read: if true;
    // }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'client' || isAdmin());
      allow update: if request.auth != null && request.auth.uid == userId && isValidUser(request.resource.data) && 
                      (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidBooking() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending';
      allow update: if isAuthenticated() && isValidBooking() && areImmutableFieldsUnchanged(['createdAt', 'userId', 'id']) && ((request.auth.uid == resource.data.userId && request.resource.data.status in ['pending', 'cancelled']) || isAdmin());
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidReview() && request.resource.data.userId == request.auth.uid && areImmutableFieldsUnchanged(['createdAt', 'userId', 'id']);
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
    }

    match /busy_slots/{slotId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
  }
}
