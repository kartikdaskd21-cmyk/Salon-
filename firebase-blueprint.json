{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the salon app (client or admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "phone": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "A salon service offered",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "durationMinutes", "isActive"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A salon appointment booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "serviceIds": { "type": "array", "items": { "type": "string" } },
        "totalAmount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "timeSlot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["id", "userId", "customerName", "serviceIds", "totalAmount", "date", "timeSlot", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "serviceIds": { "type": "array", "items": { "type": "string" } },
        "serviceNames": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "text": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["id", "userId", "customerName", "serviceIds", "serviceNames", "rating", "createdAt"]
    },
    "BusySlot": {
      "title": "BusySlot",
      "description": "A record of a booked time slot for a specific date.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Format: YYYY-MM-DD_HH:MM_AM/PM" },
        "date": { "type": "string" },
        "timeSlot": { "type": "string" }
      },
      "required": ["id", "date", "timeSlot"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/services/{serviceId}": {
      "schema": { "$ref": "#/entities/Service" },
      "description": "Available salon services"
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "Customer bookings"
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Customer reviews"
    },
    "/busy_slots/{slotId}": {
      "schema": { "$ref": "#/entities/BusySlot" },
      "description": "Booked time slots for availability checking"
    }
  }
}
